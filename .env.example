DATABASE_URL=postgresql://user:password@host:port/dbname
OPENAI_API_KEY=sk-your-key-here
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
# RMB/USD rate is now fetched live from frankfurter.app (no key needed).
# Set this only as a fallback when the live fetch fails.
# RMB_USD_RATE=0.138
# UN Comtrade API key — free registration at https://comtradeapi.un.org/
# Without this key the public preview endpoint is used (same 500-row cap, fine for testing)
COMTRADE_API_KEY=your-comtrade-key-here
